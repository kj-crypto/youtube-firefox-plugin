{
  "manifest_version": 2,
  "name": "YouTube PlayList",
  "version": "1.0",
  "description": "Managing YouTube playlist. Adding on fly and saving on local storage.",
  "background": {
    "page": "background.html"
  },
  "browser_action": {
    "default_icon": "icons/icon-48.png",
    "default_title": "Youtube Playlist",
    "default_popup": "menu/menu.html"
  },
  "icons": {
    "48": "icons/icon-48.png"
  },
  "permissions": ["webRequest", "webRequestBlocking", "tabs", "storage", "activeTab", "https://*/*"]
}
